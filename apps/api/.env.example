PF_DATABASE_URL=postgresql+asyncpg://promptforge:promptforge@localhost:5432/promptforge
PF_JWT_SECRET=change-me-to-a-real-secret-at-least-32-chars-long
PF_LOG_LEVEL=INFO
PF_CORS_ORIGINS=http://localhost:3000

# LLM provider keys (optional in dev; required for runs)
PF_OPENAI_API_KEY=
PF_ANTHROPIC_API_KEY=

# Queue tuning
PF_QUEUE_POLL_INTERVAL_MS=250
PF_QUEUE_WORKER_CONCURRENCY=4

# Demo mode
PF_DEMO_EMAIL=demo@promptforge.dev
PF_DEMO_RATE_LIMIT=5/minute
