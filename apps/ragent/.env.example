# Shared with apps/api — same values in both services.
PF_DATABASE_URL=postgresql+asyncpg://promptforge:promptforge@localhost:5432/promptforge
PF_JWT_SECRET=change-me-to-a-real-secret-at-least-32-chars-long

# Live source for the agent's system prompt (apps/api). Dev points at local API.
PF_API_BASE_URL=http://localhost:8000
PF_SYSTEM_PROMPT_CACHE_SECONDS=60

PF_LOG_LEVEL=INFO
PF_CORS_ORIGINS=http://localhost:3000

# LLM provider keys (used for embeddings + generation in later phases)
PF_OPENAI_API_KEY=
PF_ANTHROPIC_API_KEY=
