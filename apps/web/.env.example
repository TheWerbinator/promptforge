# Base URL of the PromptForge API. Read on the server (BFF) and inlined for the
# landing-page /docs link. Local dev points at the API on localhost:
#   cd apps/api && uv run uvicorn promptforge_api.main:app --reload --port 8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Base URL of the ragent service (separate app). Local dev:
#   cd apps/ragent && uv run uvicorn promptforge_ragent.main:app --reload --port 8001
NEXT_PUBLIC_RAGENT_URL=http://localhost:8001

# Secret used to seal (encrypt) the BFF session cookie. Server-only, never exposed
# to the browser. Any non-trivial string; it's hashed to a 256-bit key. Use a
# strong random value in production (e.g. `openssl rand -hex 32`).
WEB_SESSION_SECRET=dev-only-insecure-session-secret-change-me
